# ---- API (apps/api) ----
PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=avs_session
SESSION_SECRET=changeme-long-random-string
API_KEY_ENCRYPTION_SECRET=changeme-another-long-random-string
ADMIN_EMAILS=

# MongoDB connection. Point this at a local mongod, MongoDB Atlas, etc.
MONGODB_URI=mongodb://127.0.0.1:27017/aivideo

# Set to "true" to run an in-memory MongoDB (downloads a binary on first run).
# Zero external infra needed — great for local dev / the step-9 checkpoint.
USE_MEMORY_DB=false

# ---- AI ----
# At least one text AI key is required for project generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
FAL_API_KEY=
API_USAGE_MONTHLY_TOKEN_LIMIT=1000000

# ---- Render worker ----
# Fallback base URL for rendered MP4s when object storage is NOT configured
# (local dev). In production, set the S3_* vars below instead — the worker then
# uploads to object storage and ignores this.
PUBLIC_BASE_URL=http://localhost:3000

# ---- Object storage for rendered MP4s (Cloudflare R2 / S3) ----
# Required in production: the worker uploads each MP4 and sets outputUrl to the
# public object URL. Without all five, it falls back to PUBLIC_BASE_URL/videos.
# R2: endpoint = https://<accountid>.r2.cloudflarestorage.com, public = the
# bucket's r2.dev URL (or custom domain). Leave blank to disable.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ---- Stripe (Level 1 simulates checkout; key optional) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
