# Set to "true" to use mock data (no backend needed)
# Set to "false" to call the real backend at /api/*
VITE_USE_MOCKS=

# Backend API origin. Leave EMPTY for local dev (the Vite proxy forwards /api
# to http://localhost:3000) and for same-server production. Set to the API
# origin (e.g. https://your-api.onrender.com) for a split frontend/API deploy.
# Prefer leaving off /api; the app guards against accidental /api duplication.
VITE_API_BASE_URL=

# Stripe publishable key for client-side checkout
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
