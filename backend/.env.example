# ---- API (apps/api) ----
PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=avs_session
SESSION_COOKIE_SAMESITE=lax
# Set to "none" on production split frontend/API deployments.
SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_DOMAIN=
SESSION_SECRET=changeme-long-random-string
API_KEY_ENCRYPTION_SECRET=changeme-another-long-random-string
ADMIN_EMAILS=gouravsuman2006@gmail.com

# MongoDB connection. Point this at a local mongod, MongoDB Atlas, etc.
MONGODB_URI=mongodb://127.0.0.1:27017/aivideo

# Set to "true" to run an in-memory MongoDB (downloads a binary on first run).
# Zero external infra needed — great for local dev / the step-9 checkpoint.
USE_MEMORY_DB=false

# ---- AI ----
# At least one text AI key is required for code-gen. Anthropic is strongly
# recommended — it writes the best Remotion/React code. Others are fallbacks.
# Anthropic (primary) — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_PREMIUM_MODEL=claude-opus-4-8
# OpenRouter (free models available — get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
FAL_API_KEY=
KIE_API_KEY=
KIE_MODEL_TEXT_TO_VIDEO=kling-2.6/text-to-video
KIE_MODEL_IMAGE_TO_VIDEO=grok-imagine/image-to-video
KIE_MODEL_TEXT_TO_IMAGE=nano-banana-pro
# Narration voice = ElevenLabs voices via kie's Jobs API (model below). Uses the
# SAME KIE_API_KEY. Preferred over the direct ElevenLabs key (free tier 402s).
KIE_MODEL_TEXT_TO_SPEECH=elevenlabs/text-to-dialogue-v3
# ElevenLabs voice id for narration (find ids in the kie/ElevenLabs voice list).
KIE_TTS_VOICE=EkK5I93UQWFDigLMpZcX
# Force a narration provider: "kie" (real EL voices), "system" (free SAPI),
# "elevenlabs". Unset = prefer kie when configured, else auto-fallback to SAPI.
# NARRATION_PROVIDER=
# Music = kie's Suno API (POST /api/v1/generate). Uses the SAME KIE_API_KEY above
# (no separate Suno key). Model is one of V3_5, V4, V4_5, V4_5PLUS, V5.
KIE_MODEL_MUSIC=V5
# Suno requires a callBackUrl; we poll for results so this only needs to be a
# valid URL. Defaults to PUBLIC_BASE_URL/api/webhooks/suno when unset.
# KIE_CALLBACK_URL=
# Generate an instrumental music bed per video (kie/Suno). Set to 0 to disable.
GENERATE_MUSIC=1
# For prompt-only generations, create a still image first, then animate it with
# Kie image-to-video models such as grok-imagine/image-to-video.
KIE_IMAGE_TO_VIDEO_FIRST=1
# Grok Imagine image-to-video examples use 6-second clips.
KIE_GROK_VIDEO_DURATIONS=6
KIE_GROK_MODE=normal
KIE_GROK_RESOLUTION=480p
# Kie Kling 2.6 text-to-video examples use 5-second clips. If your selected
# text-to-video model supports more fixed options, set e.g. KIE_VIDEO_DURATIONS=5,10
KIE_VIDEO_DURATIONS=5
API_USAGE_MONTHLY_TOKEN_LIMIT=1000000

# ---- Render worker ----
# INLINE_WORKER=true runs the Remotion render loop inside the API process, so a
# single `npm run dev` renders videos too (handy for local dev). In production
# leave it false/unset and run the standalone worker (`npm run worker`).
INLINE_WORKER=false

# Fallback base URL for rendered MP4s when object storage is NOT configured
# (local dev). In production, set the S3_* vars below instead — the worker then
# uploads to object storage and ignores this.
PUBLIC_BASE_URL=http://localhost:3000

# ---- Object storage for rendered MP4s (Cloudflare R2 / S3) ----
# Required in production: the worker uploads each MP4 and sets outputUrl to the
# public object URL. Without all five, it falls back to PUBLIC_BASE_URL/videos.
# R2: endpoint = https://<accountid>.r2.cloudflarestorage.com, public = the
# bucket's r2.dev URL (or custom domain). Leave blank to disable.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ---- Stripe (Level 1 simulates checkout; key optional) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Local Piper TTS ----
# Used by generated videos and /api/local-tts/generate to create WAV narration locally.
PIPER_TTS_SCRIPT=C:\Users\User\Desktop\TTS LOCAL MODEL\piper\run_tts.ps1
PIPER_TTS_TIMEOUT_MS=120000

# ---- ElevenLabs voiceover (optional; if unset, no narration is generated) ----
ELEVENLABS_API_KEY=sk_763cf9c03cb0bfcbc865301fd6aef035a32c9c9ae4ef619b
ELEVENLABS_VOICE_ID=3a5c6382a1f395ac4ada1b44d0b05aca9f389600aaa196d528e107e1371522d2
